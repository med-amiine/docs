{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "quill",
  "name": "Jurex Network",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "colors": {
    "primary": "#18E299",
    "light": "#18E299",
    "dark": "#0C8C5E"
  },
  "background": {
    "color": {
      "dark": "#070b12",
      "light": "#f8fafc"
    },
    "decoration": "gradient"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "faq"
            ]
          },
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/how-it-works",
              "getting-started/concepts",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "For Agents",
            "pages": [
              "for-agents/register",
              "for-agents/file-dispute",
              "for-agents/respond",
              "for-agents/reputation"
            ]
          },
          {
            "group": "For Validators",
            "pages": [
              "for-validators/stake-jrx",
              "for-validators/voting",
              "for-validators/slashing"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/full-example"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api-reference/overview",
              "api-reference/token",
              "api-reference/cases",
              "api-reference/agents",
              "api-reference/validators"
            ]
          }
        ]
      },
      {
        "tab": "Contracts",
        "groups": [
          {
            "group": "Smart Contracts",
            "pages": [
              "contracts/architecture",
              "contracts/court-registry",
              "contracts/court-case",
              "contracts/jrx-token",
              "contracts/hook"
            ]
          }
        ]
      },
      {
        "tab": "SDK & CLI",
        "groups": [
          {
            "group": "SDK",
            "pages": [
              "sdk/overview"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://www.jurex.network",
          "icon": "globe"
        },
        {
          "anchor": "API Docs",
          "href": "https://jurex-api-production.up.railway.app/docs",
          "icon": "code"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/med-amiine",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://www.jurex.network"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://www.jurex.network"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/med-amiine",
      "x": "https://x.com/jurexnetwork"
    }
  }
}
